---
import type { CollectionEntry } from 'astro:content';

interface Props {
	note: CollectionEntry<'notes'>;
}

const { data, id } = Astro.props.note;
---

<div class="notes-entry">
	<h4 class="title"><a href={`/notes/${id}`}>{data.title}</a></h4>
	<p class="date"><em>{data.publishDate.toLocaleDateString()}</em></p>
	<p>{data.description}
		<span style="font-variant:small-caps"> <a href={`/notes/${id}`}>read more &rarr;</a> </span>
	</p>
</div>

<style>

	:global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	:global(a:hover),
	:global(a:focus) {
		text-decoration-color: currentColor;
	}

	p {
		font-size: 1.25rem;
	}

	.date {
		font-size: 1.1rem;
	}

	.notes-entry {
		margin: 2em 0;
	}
	.card {
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 11rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.title {
		/* grid-area: 1 / 1 / 2 / 2; */
	}

	img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			border-radius: 1.5rem;
		}

		.title {
			border-radius: 0.9375rem;
		}
	}
</style>
